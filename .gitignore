# ============================================================
#  ML_Manipulator - .gitignore
# ============================================================

# -------------------- Python --------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
dist/
build/
*.egg

# -------------------- Virtual Environments --------------------
.env
.venv
env/
venv/
ENV/

# -------------------- IDEs & Editors --------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# -------------------- OS Files --------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# -------------------- Data (Heavy / Generated) --------------------
# Raw and processed datasets (can be regenerated via generate_dataset.py)
data/
*.csv
*.parquet
*.h5
*.hdf5

# -------------------- Model Artifacts --------------------
# Trained models and scalers (can be retrained)
models/*.pkl
models/*.joblib
models/*.pt
models/*.h5
models/*.onnx

# -------------------- Outputs & Reports --------------------
outputs/
logs/
*.log
Plot_Documents/
plots/

# -------------------- Testing --------------------
.pytest_cache/
htmlcov/
.coverage
*.cover

# -------------------- Node / Frontend --------------------
webapp/node_modules/
webapp/dist/
webapp/.vite/

# -------------------- Misc --------------------
*.bak
*.tmp
*.temp
